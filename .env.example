# Ares Scheduler Configuration
# Copy to .env and fill in values: cp .env.example .env
#
# Prerequisites:
#   1. One "global" K8s cluster (CPU-only nodes are fine)
#   2. One or more "worker" K8s clusters (GPU nodes required)
#   3. Helm 3.x installed
#   4. Docker registry access
#
# Worker cluster config is managed per-cluster in clusters/*.yaml
# See: make init-cluster CLUSTER=<name>

# ─── Docker Registry ──────────────────────────────────────────────────────────
REGISTRY=
TAG=latest

# ─── Global Cluster Context ─────────────────────────────────────────────────
GLOBAL_K8S_CONTEXT=        # e.g. gke_ares-gpu-test_us-east4-a_ares-global

# ─── Observability ───────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=    # REQUIRED — pick a strong password for Grafana admin
